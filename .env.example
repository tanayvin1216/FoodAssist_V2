# Supabase Configuration
# Get these from your Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key
# Required for admin user management (Phase 2 Step 10): inviting users via
# supabase.auth.admin.inviteUserByEmail() and deleting users via deleteUser().
# Find it in: Supabase project settings → API → service_role (secret key).
# WARNING: This key bypasses RLS. NEVER expose it to the client bundle.
# NEVER prefix with NEXT_PUBLIC_. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# Note: Copy this file to .env.local and fill in your values
# Never commit .env.local or any file with real credentials!
